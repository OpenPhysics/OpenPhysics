{
  "extraKnownMarketplaces": {
    "openphysics": {
      "source": { "source": "github", "repo": "OpenPhysics/Baton" }
    }
  },
  "enabledPlugins": {
    "scenerystack@openphysics": true
  },
  "permissions": {
    "allow": [
      "mcp__playwright__browser_take_screenshot",
